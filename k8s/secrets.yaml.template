# ─────────────────────────────────────────────────────────
# Messmind — Kubernetes Secrets template
#
# DO NOT commit real values to Git!
# Use this as a reference. Apply with:
#   kubectl apply -f k8s/secrets.yaml -n messmind
#
# Values must be base64-encoded:
#   echo -n "your-value" | base64
# ─────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: messmind-secrets
  namespace: messmind
type: Opaque
data:
  # ── Azure SQL Database ────────────────────────────────
  # Replace each value with:  echo -n "your-actual-value" | base64
  DB_SERVER: <base64-encoded-db-server>
  DB_DATABASE: <base64-encoded-db-name>
  DB_USER: <base64-encoded-db-user>
  DB_PASSWORD: <base64-encoded-db-password>

  # ── Azure Blob Storage ────────────────────────────────
  AZURE_STORAGE_CONNECTION_STRING: <base64-encoded-connection-string>

  # ── AI API Keys ───────────────────────────────────────
  GEMINI_API_KEY: <base64-encoded-gemini-key>
  GROQ_API_KEY: <base64-encoded-groq-key>
  AZURE_API_KEY: <base64-encoded-azure-key>
  AZURE_ENDPOINT: <base64-encoded-azure-endpoint>

  # ── Content Safety ────────────────────────────────────
  AZURE_CONTENT_SAFETY_KEY: <base64-encoded-safety-key>
  AZURE_CONTENT_SAFETY_ENDPOINT: <base64-encoded-safety-endpoint>
